generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  sites      Site[]
  users      User[]
  alertRules AlertRule[]
}

model Site {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  location        String
  capacity_kw     Float
  createdAt       DateTime         @default(now())
  organization    Organization     @relation(fields: [organizationId], references: [id])
  transformers    Transformer[]
  solarGenerators SolarGenerator[]
  batteries       BatteryStorage[]
  loads           EnergyLoad[]
  devices         Device[]
}

model Transformer {
  id          String    @id @default(uuid())
  location    String
  capacity_kw Float
  siteId      String
  createdAt   DateTime  @default(now())
  site        Site      @relation(fields: [siteId], references: [id])
  devices     Device[]
}

model Device {
  id            String          @id @default(uuid())
  siteId        String
  type          String
  protocol      String          @default("MQTT")
  apiKey        String          @unique @default(uuid())
  status        String          @default("online")
  lastSeen      DateTime        @default(now())
  metadata      String?         // JSON string for device-specific config
  transformerId String?
  createdAt     DateTime        @default(now())
  site          Site            @relation(fields: [siteId], references: [id])
  transformer   Transformer?    @relation(fields: [transformerId], references: [id])
  readings      EnergyReading[]
  alerts        Alert[]
}

model EnergyReading {
  id             String   @id @default(uuid())
  deviceId       String
  voltage        Float
  current        Float
  frequency      Float
  timestamp      DateTime
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  device         Device   @relation(fields: [deviceId], references: [id])
}

model SolarGenerator {
  id          String         @id @default(uuid())
  name        String
  location    String
  siteId      String
  createdAt   DateTime       @default(now())
  site        Site           @relation(fields: [siteId], references: [id])
  readings    SolarReading[]
}

model SolarReading {
  id               String         @id @default(uuid())
  solarGeneratorId String
  power_kw         Float
  efficiency       Float
  status           String         @default("active")
  timestamp        DateTime
  createdAt        DateTime       @default(now())
  generator        SolarGenerator @relation(fields: [solarGeneratorId], references: [id])
}

model BatteryStorage {
  id          String           @id @default(uuid())
  name        String
  location    String
  siteId      String
  createdAt   DateTime         @default(now())
  site        Site             @relation(fields: [siteId], references: [id])
  readings    BatteryReading[]
}

model BatteryReading {
  id               String         @id @default(uuid())
  batteryStorageId String
  soc_percentage   Float
  charge_rate_kw   Float
  temperature      Float
  timestamp        DateTime
  createdAt        DateTime       @default(now())
  battery          BatteryStorage @relation(fields: [batteryStorageId], references: [id])
}

model EnergyLoad {
  id          String        @id @default(uuid())
  name        String
  location    String
  siteId      String
  createdAt   DateTime      @default(now())
  site        Site          @relation(fields: [siteId], references: [id])
  readings    LoadReading[]
}

model LoadReading {
  id             String     @id @default(uuid())
  energyLoadId   String
  consumption_kw Float
  peak_demand_kw Float
  status         String     @default("normal")
  timestamp      DateTime
  createdAt      DateTime   @default(now())
  load           EnergyLoad @relation(fields: [energyLoadId], references: [id])
}

model Alert {
  id            String      @id @default(uuid())
  deviceId      String
  type          String
  message       String
  severity      String      @default("WARNING")
  isResolved    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  device        Device      @relation(fields: [deviceId], references: [id])
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  email          String       @unique
  password       String
  name           String?
  role           String       @default("OPERATOR")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model AlertRule {
  id                String       @id @default(uuid())
  organizationId    String
  deviceType        String       // e.g., "transformer", "solar", "battery", "load"
  metric            String       // e.g., "voltage", "frequency", "soc", "temperature"
  warningThreshold  Float?
  criticalThreshold Float?
  condition         String       // e.g., "GREATER_THAN", "LESS_THAN", "OUTSIDE_RANGE"
  organization      Organization @relation(fields: [organizationId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}
